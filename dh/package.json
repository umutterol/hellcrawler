{
  "name": "desktop-heroes",
  "productName": "Desktop Heroes",
  "description": "Desktop Heroes",
  "version": "2.4.13",
  "main": "electron-loader.js",
  "scripts": {
    "start": "tsc --project tsconfig.electron.json && npm run start:web & sleep 5 && electron ./electron-loader.js",
    "start:linux": "npx kill-port 8080 && ELECTRON_DISABLE_SANDBOX=1 npm start",
    "start:windows": "npx kill-port 8080 && tsc --project tsconfig.electron.json && start /b npm run start:web && timeout /t 5 && electron ./electron-loader.js",
    "start:web": "vite",
    "lint": "eslint --fix ./src && prettier --write .",
    "dev": "vite",
    "build": "vite build",
    "prepare": "husky",
    "extrude": "node scripts/extruder.js",
    "tilesetData": "node scripts/parseTilemapImages.js",
    "tilesetClean": "node scripts/cleanTilemapImages.js",
    "syncLocale": "node scripts/syncLocaleFile.js",
    "localeToYml": "node scripts/localeToYml.js",
    "ymlToLocale": "node scripts/ymlToLocale.js",
    "watch:extrude": "nodemon --watch ./src/assets/sheets -e png -x \"npm run extrude\"",
    "watch:tilesetData": "nodemon --watch ./src/assets/tilemaps -e json -x \"npm run tilesetData\"",
    "watch": "npm run watch:extrude & npm run watch:tilesetData",
    "kill-port": "npx kill-port 8080",
    "package:nobuild": "electron-forge package",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "make:win": "npm run build && electron-forge make --platform win32",
    "make:mac": "npm run build && electron-forge make --platform darwin",
    "make:linux": "npm run build && electron-forge make --platform linux",
    "make:all": "npm run build && npm run make:win && npm run make:mac && npm run make:linux"
  },
  "author": "Baris Tuna <baris@telazer.com, baristna@gmail.com>",
  "license": "MIT",
  "babel": {
    "presets": [
      "@babel/preset-env"
    ]
  },
  "lint-staged": {
    "src/**/*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@telazer/event-helper": "^1.0.5",
    "@telazer/font-loader": "^1.0.1",
    "@telazer/game-ui-kit": "^1.0.24",
    "@telazer/json-bigint": "^1.0.3",
    "@telazer/number-formatter": "^1.0.1",
    "@telazer/phaser-anim-helper": "^1.0.5",
    "@telazer/phaser-audio-helper": "^1.0.5",
    "@telazer/phaser-image-helper": "^1.0.11",
    "@telazer/phaser-text-helper": "^1.0.6",
    "@telazer/steamworks": "0.4.2",
    "@telazer/version-check": "^2.0.0",
    "dotenv": "^17.2.3",
    "electron-store": "8.1.0",
    "gameanalytics": "^4.4.7",
    "i18next": "24.2.2",
    "lodash": "4.17.21",
    "moment": "2.30.1",
    "phaser": "^4.0.0-rc.4",
    "tmi.js": "^1.8.5",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@babel/core": "7.21.4",
    "@babel/preset-env": "7.21.4",
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-zip": "7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "7.8.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "4.17.5",
    "@types/tmi.js": "^1.8.6",
    "@typescript-eslint/eslint-plugin": "8.3.0",
    "babel-loader": "9.1.2",
    "copy-webpack-plugin": "11.0.0",
    "css-loader": "7.1.2",
    "dotenv-webpack": "8.1.0",
    "electron": "36.5.0",
    "eslint-plugin-prettier": "5.2.1",
    "file-loader": "6.2.0",
    "html-webpack-plugin": "5.5.0",
    "husky": "9.1.5",
    "jest": "^30.0.5",
    "js-yaml": "4.1.0",
    "lint-staged": "15.2.9",
    "mini-css-extract-plugin": "2.9.1",
    "sass": "1.77.8",
    "sass-loader": "16.0.1",
    "style-loader": "4.0.0",
    "tile-extruder": "2.1.1",
    "ts-jest": "^29.4.1",
    "ts-loader": "9.5.2",
    "ts-node": "10.9.2",
    "tsconfig-paths-webpack-plugin": "4.1.0",
    "typescript": "5.0.3",
    "vite": "^5.4.8",
    "vite-tsconfig-paths": "4.3.2",
    "webpack": "5.98.0",
    "webpack-cli": "5.0.1",
    "webpack-dev-server": "4.13.2"
  },
  "optionalDependencies": {
    "fsevents": "^2.3.3"
  }
}
